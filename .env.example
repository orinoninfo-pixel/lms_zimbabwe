# Copy to .env.local for development. In Vercel, set these under
# Project Settings > Environment Variables instead of committing a real .env.

# --- Database (Neon) ---------------------------------------------------
# Pooled connection string (hostname contains "-pooler") — used by the app
# at runtime via the Prisma driver adapter. Keeps Vercel serverless
# functions from exhausting Postgres's direct connection limit.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Unpooled/direct connection string — used only for `prisma migrate` and
# `prisma db seed` (schema DDL should not run through PgBouncer).
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- App URL -------------------------------------------------------------
# Used to build absolute links in emails and as a fallback base URL.
# Set to the real production domain in the Vercel Production environment.
APP_URL="https://your-domain.example"
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# --- Paynow (Zimbabwe payments) ------------------------------------------
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""
PAYNOW_PAYMENT_LINK=""
PAYNOW_COMPANY_NAME=""
# Must point at the deployed domain, not localhost, once live.
PAYNOW_RETURN_URL="https://your-domain.example/dashboard/billing"
PAYNOW_RESULT_URL="https://your-domain.example/api/payments/paynow/callback"

# --- Outbound email (nodemailer/SMTP) ------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
MAIL_FROM_EMAIL=""
MAIL_FROM_NAME=""

# --- Admin bootstrap (scripts/set-admin-password.ts) ---------------------
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
